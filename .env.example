# Relay server configuration
# Copy to .env and fill in required values

# REQUIRED: Secret used to sign JWT tokens (slug credentials)
# Generate with: openssl rand -hex 32
CONDUIT_JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# OPTIONAL: Registration gate token — clients must provide this to register a tunnel
# RELAY_REGISTRATION_TOKEN=

# Storage backend: memory | sqlite | postgres (default: sqlite)
STORAGE_ADAPTER=sqlite

# SQLite database path (when STORAGE_ADAPTER=sqlite)
SQLITE_PATH=/data/tunnel.db

# PostgreSQL connection string (when STORAGE_ADAPTER=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/tunnel

# Ring buffer size — max requests stored per slug (default: 1000)
RING_BUFFER_SIZE=1000

# Max request/response body to capture in bytes (default: 1048576 = 1MB)
MAX_BODY_BYTES=1048576

# Request forwarding timeout in ms (default: 30000)
FORWARD_TIMEOUT_MS=30000

# Server port (default: 3000)
PORT=3000

# Public domain the relay is hosted at (used to build tunnel URLs)
RELAY_DOMAIN=localhost:3000

# Protocol for public URLs: http or https
RELAY_PROTO=http

# OIDC auth provider (optional): set AUTH_PROVIDER=oidc to enable
# AUTH_PROVIDER=oidc
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
