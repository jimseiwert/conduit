    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^11.0.6",
    "@conduit/types": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/ws": "^8.5.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.4.5"
  }
