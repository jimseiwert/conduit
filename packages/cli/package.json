{
  "name": "@conduit/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "conduit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "build:binary": "bun build --compile src/index.ts --outfile dist/conduit --target bun --external react-devtools-core",
    "dev": "bun --watch src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
