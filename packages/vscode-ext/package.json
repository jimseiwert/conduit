{
  "name": "conduit-relay",
  "displayName": "Conduit Relay",
  "description": "Live HTTP request inspection and replay for your local server. Stream tunnel traffic directly into VS Code.",
  "version": "1.0.0",
  "publisher": "jimseiwert",
  "icon": "media/icon.png",
  "galleryBanner": { "color": "#0F172A", "theme": "dark" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Debuggers", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conduit",
          "title": "Conduit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "conduit": [
        {
          "id": "conduit.requests",
          "name": "Requests"
        }
      ]
    },
    "commands": [
      { "command": "conduit.connect", "title": "Connect Conduit" },
      { "command": "conduit.disconnect", "title": "Disconnect Conduit" },
      { "command": "conduit.login", "title": "Login (OIDC)" },
      { "command": "conduit.replay", "title": "Replay Request" },
      { "command": "conduit.refresh", "title": "Refresh" }
    ],
    "configuration": {
      "title": "Conduit",
      "properties": {
        "conduit.configFile": {
          "type": "string",
          "default": ".conduit",
          "description": "Path to conduit config file"
        },
        "conduit.relayUrl": {
          "type": "string",
          "default": "wss://relay.conduitrelay.com",
          "description": "Relay WebSocket URL"
        },
        "conduit.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect when a .conduit config file is found"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --build && node scripts/copy-assets.js",
    "vscode:prepublish": "bun run build",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "@conduit/types": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.14",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.4.5"
  }
}