{
  "name": "conduit-relay",
  "displayName": "Conduit Relay",
  "description": "Live HTTP request inspection and replay for your local server. Stream tunnel traffic directly into VS Code.",
  "version": "1.0.23",
  "publisher": "jimseiwert",
  "icon": "media/icon.png",
  "galleryBanner": { "color": "#0F172A", "theme": "dark" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Debuggers", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conduit",
          "title": "Conduit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "conduit": [
        {
          "id": "conduit.requests",
          "name": "Requests"
        }
      ]
    },
    "commands": [
      { "command": "conduit.connect", "title": "Conduit: Connect" },
      { "command": "conduit.disconnect", "title": "Conduit: Disconnect" },
      { "command": "conduit.logout", "title": "Conduit: Clear Stored Token" },
      { "command": "conduit.copyWebhookUrl", "title": "Conduit: Copy Webhook URL" },
      { "command": "conduit.inspectRequest", "title": "Conduit: Inspect Request" },
      { "command": "conduit.replay", "title": "Conduit: Replay Request" },
      { "command": "conduit.refresh", "title": "Conduit: Refresh" }
    ],
    "configuration": {
      "title": "Conduit",
      "properties": {
        "conduit.mode": {
          "type": "string",
          "enum": ["proxy", "watch"],
          "default": "proxy",
          "description": "proxy: extension forwards relay traffic to your local server. watch: extension watches traffic from an existing conduit owner (CLI or another instance)."
        },
        "conduit.localPort": {
          "type": "number",
          "default": 3000,
          "description": "Local port to forward relay traffic to (proxy mode only)"
        },
        "conduit.relayUrl": {
          "type": "string",
          "default": "wss://relay.conduitrelay.com",
          "description": "Relay WebSocket URL"
        },
        "conduit.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect on workspace open"
        },
        "conduit.registrationToken": {
          "type": "string",
          "default": "",
          "description": "Relay registration token (self-hosted only). Set this to the RELAY_REGISTRATION_TOKEN value configured on your relay server."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs && node scripts/copy-assets.js",
    "vscode:prepublish": "bun run build",
    "package": "bunx vsce package --no-dependencies"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "@conduit/types": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.14",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.5"
  }
}